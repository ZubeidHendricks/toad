{
  "name": "@toa/compiler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "toac": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
