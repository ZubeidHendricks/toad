{
  "name": "toad-compiler",
  "version": "0.4.0",
  "description": "The toac compiler for TOAD — turns a declarative .agent file (a TOON superset) into readable, fully-typed TypeScript that runs on toad-runtime.",
  "keywords": [
    "toad",
    "toac",
    "compiler",
    "ai",
    "agents",
    "anthropic",
    "claude",
    "llm",
    "toon",
    "codegen"
  ],
  "homepage": "https://zubeidhendricks.github.io/toad/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZubeidHendricks/toad.git",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/ZubeidHendricks/toad/issues"
  },
  "author": "Zubeid Hendricks",
  "license": "MIT",
  "type": "module",
  "bin": {
    "toac": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@toon-format/toon": "2.3.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
