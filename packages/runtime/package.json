{
  "name": "toad-runtime",
  "version": "0.5.0",
  "description": "Runtime for TOAD agents — the tool-use loop, structured output, and typed errors that compiled .agent modules run on, over the Anthropic API.",
  "keywords": [
    "toad",
    "ai",
    "agents",
    "anthropic",
    "claude",
    "llm",
    "tool-use",
    "toon"
  ],
  "homepage": "https://zubeidhendricks.github.io/toad/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZubeidHendricks/toad.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/ZubeidHendricks/toad/issues"
  },
  "author": "Zubeid Hendricks",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.2",
    "@toon-format/toon": "2.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
