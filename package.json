{
  "name": "toad",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.5.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "build:site": "esbuild packages/compiler/dist/index.js --bundle --format=esm --outfile=site/public/toad-compiler.js && esbuild scripts/tokenizer-entry.mjs --bundle --format=esm --outfile=site/public/toad-tokenizer.js && node scripts/gen-llms.mjs",
    "site:dev": "pnpm build:site && vitepress dev site",
    "site:build": "pnpm build:site && vitepress build site",
    "site:preview": "vitepress preview site",
    "build:vscode": "esbuild editors/vscode/src/extension.mjs --bundle --external:vscode --format=cjs --platform=node --outfile=editors/vscode/out/extension.js"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "0.28.0",
    "gpt-tokenizer": "^3.4.0",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitepress": "^1.6.4",
    "vitest": "catalog:",
    "vue": "^3.5.38"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
